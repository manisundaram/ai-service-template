# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=ai-service-template
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
MOCK_MODE=false

# =============================================================================
# Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# ENHANCED LOGGING CONFIGURATION
# =============================================================================

# Service identification
# APP_NAME and APP_ENV are defined above

# Local logging levels
LOG_LEVEL=INFO                # Console logging level
FILE_LOG_LEVEL=DEBUG          # File logging level
ERROR_FILE_LEVEL=ERROR        # Error file logging level

# Logging format and output
LOG_STRUCTURED=true           # JSON structured logs for production
LOG_CONSOLE=true              # Enable console output
LOG_DIR=./logs                # Directory for log files

# Log file rotation
LOG_MAX_FILE_SIZE=10485760    # 10MB before rotation
LOG_BACKUP_COUNT=5            # Keep 5 old files

# =============================================================================
# CLOUD LOGGING PROVIDERS (Optional - for production)
# =============================================================================

# Comma-separated list of cloud providers to enable
CLOUD_LOGGING_PROVIDERS=

# Uncomment and configure for production cloud logging:
# CLOUD_LOGGING_PROVIDERS=aws,datadog

# AWS CloudWatch (cost-optimized - errors only)
# AWS_LOGGING_ENABLED=true
# AWS_LOGGING_LEVEL=ERROR
# AWS_LOG_GROUP=/ai-service-template/production
# AWS_REGION=us-east-1

# Datadog (rich dashboards - info+)
# DATADOG_LOGGING_ENABLED=true
# DATADOG_LOGGING_LEVEL=INFO
# DATADOG_API_KEY=your-datadog-api-key

# =============================================================================
# Provider Configuration
# =============================================================================
# Which provider to use: openai, gemini, or claude
PROVIDER_TYPE=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=text-embedding-3-small

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/embedding-001

# Anthropic Claude Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-haiku-latest

# =============================================================================
# Vector Store Configuration
# =============================================================================
VECTORSTORE_BACKEND=chroma
DEFAULT_COLLECTION_NAME=default

# =============================================================================
# CORS Configuration
# =============================================================================
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
